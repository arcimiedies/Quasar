<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Quasar:Lux</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Orbit">
  <style>
    body {
      font-family: Orbit;
      text-align: center;
      color: white;
  background-repeat: no-repeat;
  background-attachment: fixed; 
  background-size: 100% 100%;
      background-image: url('https://img.magnific.com/free-photo/background-golden-particle-dust-powder_1017-32800.jpg?semt=ais_hybrid&w=740&q=80');
    }
    .gallery {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-top: 2em;
      justify-content: flex-start;
    }
    .card {
      border: 1px solid #d4af37;
      border-radius: 10px;
      padding: 20px;
      width: 220px;
      text-align: center;
      background-color: #66195589;
      box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .card h3 {
      margin: 0 0 10px;
    }
    .card button,
    .card select {
      font-size: 1em;
      font-family: orbit;
      color: white;
      border: 1px solid #d4af37;
      border-radius: 10px;
      background-color: #BFd4af37;
      margin: 8px 0;
      padding: 5px 10px;
    }
    .card button {
      background-color: #99d4af37;
      color: white;
      border: none;
      border-radius: 3px;
      cursor: pointer;
    }
    .card button:hover {
      background-color: #BFd4af37;
    }
    label {
      display: block;
      margin-bottom: 8px;
      font-weight: bold;
      font-size: 1.05em;
    }
  </style>
</head>
<body>
<h1 style= ”color:#fff;”> Quasar: Lux </h1>
<h3> Games Launcher </h3>
<p> Human made, built from the ground up for a proper experience</p>
  <div class="gallery" id="gallery"></div>

  <script>
    const fileList = [
      { name: "Indev", url: "https://raw.githubusercontent.com/bubbls/ugs-singlefile/refs/heads/main/UGS-Files/clEaglercraft-Indev-Offline.html", ui: "dropdown" },
      { name: "Alpha 1.2.6", url: "https://raw.githubusercontent.com/bubbls/ugs-singlefile/refs/heads/main/UGS-Files/clEaglercraft-Alpha-126-Offline.html", ui: "dropdown" },
      { name: "Beta 1.3", url: "https://raw.githubusercontent.com/bubbls/ugs-singlefile/refs/heads/main/UGS-Files/clEaglercraft-Beta-13-Offline.html", ui: "dropdown" },
      { name: "1.5.2", url: "https://raw.githubusercontent.com/bubbls/ugs-singlefile/refs/heads/main/UGS-Files/cleaglercraft152.html", ui: "dropdown" },
      { name: "1.9.4", url:  "https://raw.githubusercontent.com/bubbls/ugs-singlefile/refs/heads/main/UGS-Files/clEaglercraftL_19_v0_7_0_Offline_Signed.html", ui: "dropdown" },
      { name: "1.11.2", url: "https://raw.githubusercontent.com/denduednue/ykyk/refs/heads/main/EaglercraftZ_1.11.2.html", ui: "dropdown" },
      { name: "1.12", url: "https://raw.githubusercontent.com/arcimiedies/nothing-to-see-here/refs/heads/main/Eaglecraft%201.12", ui: "dropdown" },

      { name: "Balatro", game: "Rougelike Joker Poker", url: "https://raw.githubusercontent.com/9kwngxqj4q-stack/Balatro/refs/heads/main/balatro.html", ui: "card" },
      { name: "N-GON", game: "Sci Fi Sidescroller", url: "https://raw.githubusercontent.com/denduednue/n-gon/refs/heads/master/index%20copy.html", ui: "card" },
      { name: "Slime Ranchers", game: "Slime Rancher", url: "https://raw.githubusercontent.com/denduednue/ranch/refs/heads/main/index%20copy.html", ui: "card" },
      { name: "Sandboxels", game: "Falling Sand Game", url: "https://raw.githubusercontent.com/R74nCom/sandboxels/refs/heads/main/index.html", ui: "card" },
      { name: "Atlas", game: "Alternative Launcher, made by Max Z and Tavira", url: "https://raw.githubusercontent.com/CorduroyBrick49/Atlas/refs/heads/main/index.html", ui: "card" },
      { name: "Space Company", game: "Text Based Incremental Game", url: "https://raw.githubusercontent.com/arcimiedies/nothing-to-see-here/refs/heads/main/clspacecompany.html", ui: "card" },
      { name: "Drive Mad", game: "Car game", url: "https://raw.githubusercontent.com/arcimiedies/nothing-to-see-here/refs/heads/main/dirve-mud.html", ui: "card" }
    ];

    const galleryDiv = document.getElementById('gallery');


    const dropdownCard = document.createElement('div');
    dropdownCard.className = 'card';
    dropdownCard.innerHTML = `
      <h3>Minecraft</h3>
      <label for="fileSelect">Classic Block Game</label>
      <select id="fileSelect">
        <option value="" disabled selected>Select Version</option>
      </select>
      <button id="openBtn" disabled style="width:100%;">Open in about:blank</button>
    `;
    galleryDiv.appendChild(dropdownCard);


    const select = dropdownCard.querySelector('#fileSelect');
    const btn = dropdownCard.querySelector('#openBtn');
    fileList
      .filter(item => item.ui === "dropdown")
      .forEach(file =>
        select.add(new Option(file.name, file.url))
      );
    select.addEventListener('change', () => {
      btn.disabled = !select.value;
    });
    btn.addEventListener('click', async () => {
      const url = select.value;
      await openFile(url);
    });


    fileList
      .filter(item => item.ui === "card")
      .forEach(item => {
        const card = document.createElement('div');
        card.className = 'card';

        const title = document.createElement('h3');
        title.textContent = item.name;
        card.appendChild(title);

        if (item.game) {
          const gameInfo = document.createElement('p');
          gameInfo.textContent = item.game;
          card.appendChild(gameInfo);
        }

        const button = document.createElement('button');
        button.textContent = 'Play Now';
        button.onclick = () => openFile(item.url);
        card.appendChild(button);

        galleryDiv.appendChild(card);
      });


    async function openFile(url) {
      try {
        const res = await fetch(url);
        if (!res.ok) throw new Error(`Fetch failed: ${res.status} ${res.statusText}`);
        let html = await res.text();

        const baseHref = url.slice(0, url.lastIndexOf('/') + 1);
        if (/<head[^>]*>/i.test(html)) {
          html = html.replace(/<head([^>]*)>/i, `<head$1><base href="${baseHref}">`);
        } else {
          html = `<head><base href="${baseHref}"></head>` + html;
        }

        const w = window.open('about:blank');
        if (!w) throw new Error('Popup blocked — allow popups for this site.');
        w.document.open();
        w.document.write(html);
        w.document.close();
      } catch (err) {
        console.error('Error loading remote HTML:', err);
        alert('Error loading remote HTML: ' + err.message);
      }
    }
  </script>
</body>
</html>


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Launch</title>


 <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Orbit">
  <style>
    body {
      font-family: Orbit;
      text-align: center;
      color: white;
  background-repeat: no-repeat;
  background-attachment: fixed; 
  background-size: 100% 100%;
      background-image: url('https://img.magnific.com/free-photo/background-golden-particle-dust-powder_1017-32800.jpg?semt=ais_hybrid&w=740&q=80');
    }
    .gallery {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-top: 2em;
      justify-content: flex-start;
    }
    .card {
      border: 1px solid #d4af37;
      border-radius: 10px;
      font-family: orbit;
      font-size: 2em;
      color: white;
      margin:auto; 
      display:block;
      padding: 20px;
      width: 220px;
      text-align: center;
      background-color: #66195589;
      box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);
      display: flex;
      flex-direction: column;
      align-items: center;

  </style>
</head>

<body>

<h1> Quasar: Lux Launcher </h1>

<button class="card button" onclick="launchGame()">Launch</button>

<script>
async function launchGame() {

   const url = "https://raw.githubusercontent.com/arcimiedies/Quasar/refs/heads/main/Index";

   try {
      const res = await fetch(url);
      let html = await res.text();

      const base = url.slice(0, url.lastIndexOf("/") + 1);

      if (/<head/i.test(html)) {
         html = html.replace(
            /<head([^>]*)>/i,
            `<head$1><base href="${base}">`
         );
      } else {
         html = `<head><base href="${base}"></head>` + html;
      }

      const w = window.open("about:blank");
      w.document.write(html);
      w.document.close();

   } catch (err) {
      alert("Failed to load game.");
      console.error(err);
   }
}
</script>

</body>
</html>




<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Atlas</title>
        <link
            rel="icon"
            type="image/x-icon"
            href="https://github.com/CorduroyBrick49/Atlas/blob/main/AtlasIcon.ico?raw=true"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap"
            rel="stylesheet"
        />
        <style>
            *,
            *::before,
            *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --bg: #0b0b12;
                --card: rgba(20, 20, 35, 0.7);
                --border: rgba(168, 85, 247, 0.25);
                --text: #ffffff;
                --muted: #cbd5e1;
                --accent1: #a855f7;
                --accent2: #6366f1;
                --bg-image: none;
                --cardText: #d3d3d3;
                --radius-sm: 8px;
                --radius-md: 10px;
                --radius-lg: 14px;
                --radius-xl: 18px;
                --transition-fast: 0.15s ease;
                --transition-med: 0.25s ease;
                --transition-slow: 0.35s ease;
            }

            html {
                font-size: 16px;
            }

            body {
                font-family:
                    "Manrope",
                    -apple-system,
                    BlinkMacSystemFont,
                    "Segoe UI",
                    sans-serif;
                min-height: 100vh;
                display: flex;
                background: var(--bg);
                color: var(--text);
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
                transition:
                    background var(--transition-slow),
                    color var(--transition-slow);
            }

            body::before {
                content: "";
                position: fixed;
                inset: 0;
                z-index: -1;
                background-image: var(--bg-image);
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                opacity: 0.35;
                pointer-events: none;
                transition:
                    background-image var(--transition-slow),
                    opacity var(--transition-slow);
            }

            /* ── SIDEBAR ── */
            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                width: 260px;
                height: 100vh;
                z-index: 10;
                padding: 22px 16px;
                display: flex;
                flex-direction: column;
                gap: 14px;
                background: var(--card);
                backdrop-filter: blur(16px);
                -webkit-backdrop-filter: blur(16px);
                border-right: 1px solid var(--border);
                overflow-y: auto;
                overflow-x: hidden;
                transition:
                    background var(--transition-slow),
                    border-color var(--transition-slow);
            }

            .sidebar::-webkit-scrollbar {
                width: 4px;
            }
            .sidebar::-webkit-scrollbar-thumb {
                background: var(--border);
                border-radius: 4px;
            }

            .logo {
                font-size: 1.6rem;
                font-weight: 800;
                letter-spacing: -0.02em;
                background: linear-gradient(135deg, var(--accent1), var(--accent2));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 2px 0 6px;
                user-select: none;
            }

            .logo svg {
                flex-shrink: 0;
                /* SVG stroke inherits from color but we need to override text-fill */
                stroke: var(--accent1);
            }

            .sidebar-label {
                font-size: 0.7rem;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--muted);
                opacity: 0.6;
                padding: 0 4px;
            }

            .sidebar hr {
                border: none;
                border-top: 1px solid var(--border);
                margin: 2px 0;
            }

            /* ── SEARCH ── */
            .search {
                width: 100%;
                padding: 10px 14px;
                border-radius: var(--radius-md);
                border: 1px solid var(--border);
                background: rgba(0, 0, 0, 0.2);
                color: var(--text);
                font-family: inherit;
                font-size: 0.875rem;
                font-weight: 400;
                outline: none;
                transition:
                    border-color var(--transition-fast),
                    background var(--transition-fast);
            }

            .search::placeholder {
                color: var(--muted);
                opacity: 0.6;
            }

            .search:focus {
                border-color: var(--accent1);
                background: rgba(0, 0, 0, 0.3);
            }

            /* ── GENRE PILLS ── */
            .genres {
                display: flex;
                flex-wrap: wrap;
                gap: 5px;
            }

            .genre-btn {
                padding: 5px 10px;
                border-radius: 999px;
                border: 1px solid var(--border);
                font-family: inherit;
                font-size: 0.72rem;
                font-weight: 600;
                cursor: pointer;
                background: rgba(0, 0, 0, 0.15);
                color: var(--muted);
                transition:
                    transform var(--transition-fast),
                    border-color var(--transition-fast),
                    background var(--transition-fast),
                    color var(--transition-fast);
                line-height: 1;
            }

            .genre-btn:hover {
                transform: translateY(-1px);
                border-color: var(--accent1);
                color: var(--text);
            }

            .genre-btn.active {
                background: linear-gradient(135deg, var(--accent1), var(--accent2));
                color: #fff;
                border-color: transparent;
            }

            /* ── FAVORITES ── */
            .favorites-list {
                display: flex;
                flex-direction: column;
                gap: 6px;
            }

            .fav-item {
                padding: 10px 12px;
                border-radius: var(--radius-md);
                border: 1px solid var(--border);
                color: #fff;
                cursor: pointer;
                font-family: inherit;
                font-size: 0.82rem;
                font-weight: 600;
                text-align: left;
                background-size: cover;
                background-position: center;
                display: flex;
                align-items: center;
                transition:
                    transform var(--transition-med),
                    border-color var(--transition-med),
                    filter var(--transition-med);
                position: relative;
                overflow: hidden;
                min-height: 40px;
            }

            .fav-item::before {
                content: "";
                position: absolute;
                inset: 0;
                background: rgba(0, 0, 0, 0.45);
                z-index: 0;
            }

            .fav-item span {
                position: relative;
                z-index: 1;
            }

            .fav-item:hover {
                transform: translateY(-2px);
                border-color: var(--accent1);
                filter: brightness(1.15);
            }

            .fav-empty {
                font-size: 0.78rem;
                color: var(--muted);
                opacity: 0.5;
                padding: 4px;
            }

            /* ── THEME BUTTONS ── */
            .theme-btn {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 9px 12px;
                border-radius: var(--radius-md);
                border: 1px solid var(--border);
                background: rgba(0, 0, 0, 0.15);
                color: var(--muted);
                font-family: inherit;
                font-size: 0.82rem;
                font-weight: 500;
                cursor: pointer;
                transition:
                    transform var(--transition-fast),
                    border-color var(--transition-fast),
                    background var(--transition-fast),
                    color var(--transition-fast);
            }

            .theme-btn:hover {
                transform: translateY(-1px);
                border-color: var(--accent1);
                color: var(--text);
            }

            .theme-btn.active {
                background: linear-gradient(135deg, var(--accent1), var(--accent2));
                color: #fff;
                border-color: transparent;
            }

            .theme-swatch {
                width: 10px;
                height: 10px;
                border-radius: 50%;
                flex-shrink: 0;
            }

            /* ── MAIN ── */
            .main {
                flex: 1;
                margin-left: 260px;
                padding: 32px 32px 48px;
            }

            .header {
                margin-bottom: 4px;
            }

            .header h1 {
                font-size: 2.6rem;
                font-weight: 800;
                letter-spacing: -0.03em;
                line-height: 1;
            }

            .header p {
                margin-top: 6px;
                font-size: 0.9rem;
                color: var(--muted);
                font-weight: 400;
            }

            /* ── GAME GRID ── */
            .container {
                margin-top: 24px;
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
                gap: 16px;
            }

            .box {
                position: relative;
                overflow: hidden;
                display: flex;
                flex-direction: column;
                min-height: 210px;
                padding: 16px;
                border-radius: var(--radius-xl);
                border: 1px solid var(--border);
                background: var(--card);
                backdrop-filter: blur(10px);
                -webkit-backdrop-filter: blur(10px);
                animation: cardPopIn 0.35s ease both;
                transition:
                    transform var(--transition-med),
                    box-shadow var(--transition-med),
                    border-color var(--transition-med),
                    filter var(--transition-med);
                cursor: default;
            }

            .box:hover {
                transform: translateY(-6px) scale(1.005);
                filter: brightness(1.1);
                border-color: var(--accent1);
                box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
            }

            .box * {
                position: relative;
                z-index: 1;
            }

            .box h3 {
                font-size: 1.05rem;
                font-weight: 700;
                margin-bottom: 5px;
                color: var(--cardText);
                line-height: 1.2;
            }

            .box p {
                font-size: 0.82rem;
                line-height: 1.5;
                color: var(--cardText);
                opacity: 0.85;
                flex: 1;
                margin-bottom: 12px;
            }

            .card-top {
                display: flex;
                flex-direction: column;
                gap: 8px;
                margin-bottom: 8px;
                flex: 1;
            }

            .card-topbar {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                gap: 8px;
            }

            .genre-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 5px;
            }

            .genre-tag {
                font-size: 0.67rem;
                font-weight: 600;
                padding: 3px 8px;
                border-radius: 999px;
                border: 1px solid var(--border);
                color: var(--muted);
                background: rgba(0, 0, 0, 0.2);
                line-height: 1;
            }

            /* ── FAVORITE BUTTON ── */
            .favorite-btn {
                width: 24px;
                height: 24px;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0;
                line-height: 1;
                font-size: 13px;
                border-radius: var(--radius-sm);
                cursor: pointer;
                background: rgba(0, 0, 0, 0.3);
                border: 1px solid rgba(255, 255, 255, 0.12);
                color: rgba(255, 255, 255, 0.5);
                transition:
                    transform var(--transition-fast),
                    border-color var(--transition-fast),
                    background var(--transition-fast),
                    color var(--transition-fast),
                    box-shadow var(--transition-fast);
            }

            .favorite-btn:hover {
                transform: scale(1.1);
                border-color: rgba(255, 213, 74, 0.5);
                color: rgba(255, 213, 74, 0.8);
            }

            .favorite-btn.active {
                color: #ffd54a;
                border-color: rgba(255, 213, 74, 0.5);
                background: rgba(255, 213, 74, 0.12);
                box-shadow: 0 0 8px rgba(255, 213, 74, 0.3);
                animation: favPop 0.25s ease;
            }

            .favorite-btn:active {
                transform: scale(0.88);
            }

            /* ── LAUNCH BUTTON ── */
            .launch-btn {
                width: 100%;
                padding: 9px 14px;
                border-radius: var(--radius-md);
                border: none;
                font-family: inherit;
                font-size: 0.82rem;
                font-weight: 700;
                cursor: pointer;
                background: linear-gradient(135deg, var(--accent1), var(--accent2));
                color: #fff;
                letter-spacing: 0.01em;
                transition:
                    filter var(--transition-fast),
                    transform var(--transition-fast);
                margin-top: auto;
            }

            .launch-btn:hover {
                filter: brightness(1.15);
                transform: translateY(-2px);
            }

            .launch-btn:active {
                transform: translateY(1px);
                filter: brightness(0.95);
            }

            /* ── TOP-RIGHT ICON BUTTONS ── */
            .icon-btn {
                position: fixed;
                top: 14px;
                z-index: 1000;
                width: 34px;
                height: 34px;
                border-radius: var(--radius-md);
                border: 1px solid var(--border);
                background: var(--card);
                color: var(--muted);
                cursor: pointer;
                padding: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                backdrop-filter: blur(14px);
                -webkit-backdrop-filter: blur(14px);
                transition:
                    border-color var(--transition-fast),
                    color var(--transition-fast),
                    background var(--transition-fast),
                    transform var(--transition-fast);
            }

            .icon-btn svg {
                display: block;
                flex-shrink: 0;
            }

            .icon-btn:hover {
                border-color: var(--accent1);
                color: var(--text);
                transform: scale(1.06);
            }

            .icon-btn.active {
                border-color: var(--accent1);
                color: var(--accent1);
                background: rgba(168, 85, 247, 0.1);
            }

            #cloak-btn {
                right: 14px;
            }
            #settings-btn {
                right: 56px;
            }

            /* ── PANELS ── */
            .panel {
                position: fixed;
                right: 14px;
                z-index: 1000;
                width: 295px;
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius-xl);
                backdrop-filter: blur(22px);
                -webkit-backdrop-filter: blur(22px);
                padding: 16px;
                display: flex;
                flex-direction: column;
                gap: 12px;
                opacity: 0;
                pointer-events: none;
                transform: translateY(-6px) scale(0.98);
                transition:
                    opacity 0.2s ease,
                    transform 0.2s ease;
            }

            .panel.open {
                opacity: 1;
                pointer-events: all;
                transform: translateY(0) scale(1);
            }

            #cloak-panel {
                top: 56px;
            }
            #settings-panel {
                top: 56px;
            }

            .panel-header h4 {
                font-size: 0.9rem;
                font-weight: 700;
                color: var(--text);
                margin-bottom: 2px;
            }

            .panel-header p {
                font-size: 0.72rem;
                color: var(--muted);
                opacity: 0.7;
            }

            /* ── CLOAK PRESETS ── */
            .cloak-presets {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 6px;
            }

            .preset-btn {
                padding: 9px 8px;
                border-radius: var(--radius-md);
                border: 1px solid var(--border);
                background: rgba(0, 0, 0, 0.15);
                color: var(--muted);
                cursor: pointer;
                font-family: inherit;
                font-size: 0.72rem;
                font-weight: 600;
                text-align: center;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 5px;
                transition:
                    border-color var(--transition-fast),
                    color var(--transition-fast),
                    background var(--transition-fast),
                    transform var(--transition-fast);
            }

            .preset-btn:hover {
                border-color: var(--accent1);
                color: var(--text);
                transform: translateY(-1px);
            }

            .preset-btn.selected {
                background: linear-gradient(135deg, var(--accent1), var(--accent2));
                color: #fff;
                border-color: transparent;
            }

            .preset-icon {
                width: 18px;
                height: 18px;
                border-radius: 4px;
                object-fit: contain;
                display: block;
            }

            .preset-icon-fallback {
                width: 18px;
                height: 18px;
                border-radius: 4px;
                background: rgba(255, 255, 255, 0.1);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 10px;
            }

            /* ── CLOAK INPUTS ── */
            .cloak-custom {
                display: flex;
                flex-direction: column;
                gap: 6px;
            }

            .cloak-custom label {
                font-size: 0.72rem;
                font-weight: 600;
                color: var(--muted);
                opacity: 0.7;
            }

            .panel-input {
                padding: 8px 10px;
                border-radius: var(--radius-sm);
                border: 1px solid var(--border);
                background: rgba(0, 0, 0, 0.2);
                color: var(--text);
                font-family: inherit;
                font-size: 0.8rem;
                outline: none;
                width: 100%;
                transition:
                    border-color var(--transition-fast),
                    background var(--transition-fast);
            }

            .panel-input::placeholder {
                color: var(--muted);
                opacity: 0.5;
            }
            .panel-input:focus {
                border-color: var(--accent1);
                background: rgba(0, 0, 0, 0.3);
            }

            /* ── PANEL ACTION BUTTONS ── */
            .btn-primary {
                padding: 9px 14px;
                border-radius: var(--radius-md);
                border: none;
                cursor: pointer;
                background: linear-gradient(135deg, var(--accent1), var(--accent2));
                color: #fff;
                font-family: inherit;
                font-size: 0.82rem;
                font-weight: 700;
                transition:
                    filter var(--transition-fast),
                    transform var(--transition-fast);
            }

            .btn-primary:hover {
                filter: brightness(1.12);
                transform: translateY(-1px);
            }
            .btn-primary:active {
                transform: translateY(0);
                filter: brightness(0.95);
            }

            .btn-ghost {
                padding: 8px 14px;
                border-radius: var(--radius-md);
                border: 1px solid var(--border);
                cursor: pointer;
                background: rgba(0, 0, 0, 0.15);
                color: var(--muted);
                font-family: inherit;
                font-size: 0.8rem;
                font-weight: 500;
                transition:
                    border-color var(--transition-fast),
                    color var(--transition-fast),
                    background var(--transition-fast),
                    transform var(--transition-fast);
            }

            .btn-ghost:hover {
                border-color: rgba(255, 100, 100, 0.45);
                color: #ff7070;
                transform: translateY(-1px);
            }

            .btn-ghost:active {
                transform: translateY(0);
            }

            .cloak-status {
                font-size: 0.72rem;
                font-weight: 600;
                text-align: center;
                padding: 6px 10px;
                border-radius: var(--radius-sm);
                background: rgba(168, 85, 247, 0.08);
                border: 1px solid rgba(168, 85, 247, 0.2);
                color: var(--accent1);
                display: none;
            }

            .cloak-status.visible {
                display: block;
            }

            /* ── LOADING SCREEN ── */
            #loading-screen {
                position: fixed;
                inset: 0;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                gap: 14px;
                background: rgba(5, 8, 18, 0.88);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                z-index: 9999;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.2s ease;
            }

            #loading-screen.active {
                opacity: 1;
                pointer-events: all;
            }

            .loader {
                width: 42px;
                height: 42px;
                border: 3px solid rgba(255, 255, 255, 0.12);
                border-top-color: var(--accent1);
                border-radius: 50%;
                animation: spin 0.8s linear infinite;
            }

            #loading-screen p {
                font-size: 0.85rem;
                font-weight: 500;
                color: var(--muted);
            }

            /* ── TOAST POPUP ── */
            .toast {
                position: fixed;
                top: 18px;
                left: 50%;
                transform: translateX(-50%) translateY(-4px);
                padding: 8px 16px;
                border-radius: 999px;
                font-size: 0.82rem;
                font-weight: 600;
                background: var(--card);
                border: 1px solid var(--border);
                backdrop-filter: blur(14px);
                color: var(--text);
                opacity: 0;
                transition:
                    opacity 0.2s ease,
                    transform 0.2s ease;
                z-index: 9999;
                pointer-events: none;
                white-space: nowrap;
            }

            .toast.show {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }

            /* ── SCROLLBAR ── */
            ::-webkit-scrollbar {
                width: 8px;
            }
            ::-webkit-scrollbar-track {
                background: transparent;
            }
            ::-webkit-scrollbar-thumb {
                background: linear-gradient(180deg, var(--accent1), var(--accent2));
                border-radius: 8px;
            }
            * {
                scrollbar-width: thin;
                scrollbar-color: var(--accent1) transparent;
            }

            /* ── ANIMATIONS ── */
            @keyframes spin {
                to {
                    transform: rotate(360deg);
                }
            }

            @keyframes favPop {
                0% {
                    transform: scale(0.75);
                }
                60% {
                    transform: scale(1.25);
                }
                100% {
                    transform: scale(1);
                }
            }

            @keyframes cardPopIn {
                from {
                    opacity: 0;
                    transform: translateY(12px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @media (prefers-reduced-motion: reduce) {
                *,
                *::before,
                *::after {
                    animation-duration: 0.01ms !important;
                    transition-duration: 0.01ms !important;
                }
            }
        </style>
    </head>
    <body>
        
        <button class="icon-btn" id="cloak-btn" title="Tab Cloaking" aria-label="Tab Cloaking">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M2 12C2 12 5 5 12 5s10 7 10 7-3 7-10 7S2 12 2 12z" />
                <circle cx="12" cy="12" r="3" />
                <line x1="3" y1="3" x2="21" y2="21" />
            </svg>
        </button>

        <button class="icon-btn" id="settings-btn" title="Settings" aria-label="Settings">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >

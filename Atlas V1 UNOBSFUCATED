            /* ── THEME ── */
            const Theme = {
                apply(name) {
                    const t = THEMES[name];
                    if (!t) return;
                    const r = document.documentElement;
                    const map = {
                        "--bg": t.bg,
                        "--card": t.card,
                        "--border": t.border,
                        "--text": t.text,
                        "--muted": t.muted,
                        "--accent1": t.accent1,
                        "--accent2": t.accent2,
                        "--cardText": t.cardText,
                        "--bg-image": t.bgImage ? `url(${t.bgImage})` : "none",
                    };
                    Object.entries(map).forEach(([k, v]) => r.style.setProperty(k, v));
                    localStorage.setItem("atlas_theme", name);
                    DOM.themeBtns.forEach((b) => b.classList.toggle("active", b.dataset.theme === name));
                },
                getPreferred() {
                    const saved = localStorage.getItem("atlas_theme");
                    if (saved && THEMES[saved]) return saved;
                    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
                },
                init() {
                    DOM.themeBtns.forEach((btn) => {
                        btn.onclick = (e) => {
                            e.stopPropagation();
                            Theme.apply(btn.dataset.theme);
                        };
                    });
                },
            };

            /* ── TOAST ── */
            const Toast = {
                el: null,
                timer: null,
                show(msg) {
                    if (!this.el) {
                        this.el = document.createElement("div");
                        this.el.className = "toast";
                        document.body.appendChild(this.el);
                    }
                    this.el.textContent = msg;
                    clearTimeout(this.timer);
                    requestAnimationFrame(() => {
                        this.el.classList.add("show");
                        this.timer = setTimeout(() => this.el.classList.remove("show"), 2000);
                    });
                },
            };

            /* ── FAVORITES ── */
            const Favorites = {
                save() {
                    localStorage.setItem("atlas_favorites", JSON.stringify(STATE.favorites));
                    this.render();
                },
                toggle(item) {
                    const idx = STATE.favorites.findIndex((f) => f.name === item.name);
                    if (idx === -1) {
                        if (STATE.favorites.length >= STATE.MAX_FAVORITES) {
                            Toast.show("Max 5 favorites reached");
                            return;
                        }
                        STATE.favorites.push(item);
                        Toast.show(`★ Added "${item.name}"`);
                    } else {
                        STATE.favorites.splice(idx, 1);
                        Toast.show(`Removed "${item.name}"`);
                    }
                    this.save();
                    this.updateStars();
                },
                render() {
                    DOM.favoritesBar.innerHTML = "";
                    if (!STATE.favorites.length) {
                        DOM.favoritesBar.innerHTML = `<div class="fav-empty">No favorites yet</div>`;
                        return;
                    }
                    STATE.favorites.forEach((item) => {
                        const btn = document.createElement("button");
                        btn.className = "fav-item";
                        btn.style.backgroundImage = `url(${item.image})`;
                        btn.innerHTML = `<span>${item.name}</span>`;
                        btn.onclick = () => Game.open(item.url);
                        DOM.favoritesBar.appendChild(btn);
                    });
                },
                updateStars() {
                    document.querySelectorAll(".box").forEach((box) => {
                        const name = box.querySelector("h3").textContent;
                        box.querySelector(".favorite-btn").classList.toggle(
                            "active",
                            STATE.favorites.some((f) => f.name === name)
                        );
                    });
                },
            };

            /* ── GAME LAUNCHER ── */
            const Game = {
                open(url) {
                    DOM.loader.classList.add("active");
                    setTimeout(() => {
                        fetch(url)
                            .then((r) => r.text())
                            .then((html) => {
                                const base = url.slice(0, url.lastIndexOf("/") + 1);
                                html = /<head/i.test(html)
                                    ? html.replace(/<head([^>]*)>/i, `<head$1><base href="${base}">`)
                                    : `<head><base href="${base}"></head>` + html;
                                const w = window.open("about:blank");
                                w.document.write(html);
                                w.document.close();
                                DOM.loader.classList.remove("active");
                            })
                            .catch(() => {
                                DOM.loader.classList.remove("active");
                                Toast.show("Failed to load game.");
                            });
                    }, 350);
                },
            };

            /* ── GENRES ── */
            const Genres = {
                init() {
                    const genres = ["All", ...new Set(data.flatMap((g) => g.genres))];
                    genres.forEach((g) => {
                        const btn = document.createElement("button");
                        btn.className = "genre-btn" + (g === "All" ? " active" : "");
                        btn.textContent = g;
                        btn.onclick = () => {
                            document.querySelectorAll(".genre-btn").forEach((b) => b.classList.remove("active"));
                            btn.classList.add("active");
                            STATE.activeGenre = g;
                            Filters.apply();
                        };
                        DOM.genreBar.appendChild(btn);
                    });
                },
            };

            /* ── CARD RENDERING ── */
            const UI = {
                render(list) {
                    DOM.container.innerHTML = "";
                    if (!list.length) {
                        DOM.container.innerHTML = `<div style="grid-column:1/-1;color:var(--muted);opacity:.6;padding:40px 0;font-size:.9rem;">No games found.</div>`;
                        return;
                    }
                    list.forEach((item, i) => {
                        const isFav = STATE.favorites.some((f) => f.name === item.name);
                        const box = document.createElement("div");
                        box.className = "box";
                        box.style.animationDelay = `${Math.min(i * 0.04, 0.5)}s`;
                        box.dataset.image = item.image;

                        box.innerHTML = `
                        <div class="card-top">
                            <div class="card-topbar">
                                <div class="genre-tags">${item.genres.map((g) => `<span class="genre-tag">${g}</span>`).join("")}</div>
                                <button class="favorite-btn${isFav ? " active" : ""}" aria-label="Favorite ${item.name}" title="${isFav ? "Remove from favorites" : "Add to favorites"}">★</button>
                            </div>
                            <h3>${item.name}</h3>
                            <p>${item.description}</p>
                        </div>
                        <button class="launch-btn">Launch Game</button>
                    `;

                        box.querySelector(".favorite-btn").onclick = (e) => {
                            e.stopPropagation();
                            Favorites.toggle(item);
                        };
                        box.querySelector(".launch-btn").onclick = () => Game.open(item.url);
                        DOM.container.appendChild(box);
                    });
                    this.lazyLoad();
                },

                lazyLoad() {
                    const obs = new IntersectionObserver(
                        (entries, o) => {
                            entries.forEach((entry) => {
                                if (!entry.isIntersecting) return;
                                const box = entry.target;
                                if (box.dataset.image) {
                                    box.style.backgroundImage = `linear-gradient(rgba(0,0,0,0.52),rgba(0,0,0,0.52)),url(${box.dataset.image})`;
                                    box.style.backgroundSize = "cover";
                                    box.style.backgroundPosition = "center";
                                }
                                o.unobserve(box);
                            });
                        },
                        { rootMargin: "250px" }
                    );
                    document.querySelectorAll(".box[data-image]").forEach((b) => obs.observe(b));
                },
            };

            /* ── FILTERS ── */
            const Filters = {
                apply() {
                    const q = DOM.search.value.toLowerCase().trim();
                    const filtered = data.filter((item) => {
                        const textMatch =
                            !q ||
                            item.name.toLowerCase().includes(q) ||
                            item.description.toLowerCase().includes(q) ||
                            item.genres.some((g) => g.toLowerCase().includes(q));
                        const genreMatch = STATE.activeGenre === "All" || item.genres.includes(STATE.activeGenre);
                        return textMatch && genreMatch;
                    });
                    UI.render(filtered);
                },
            };

            /* ── PANELS ── */
            const Panels = {
                closeAll() {
                    [DOM.cloakPanel, DOM.settingsPanel].forEach((p) => p.classList.remove("open"));
                    [DOM.cloakBtn, DOM.settingsBtn].forEach((b) => b.classList.remove("active"));
                },
                toggle(panel, button) {
                    const wasOpen = panel.classList.contains("open");
                    this.closeAll();
                    if (!wasOpen) {
                        panel.classList.add("open");
                        button.classList.add("active");
                    }
                },
                init() {
                    DOM.cloakBtn.onclick = (e) => {
                        e.stopPropagation();
                        Panels.toggle(DOM.cloakPanel, DOM.cloakBtn);
                    };
                    DOM.settingsBtn.onclick = (e) => {
                        e.stopPropagation();
                        Panels.toggle(DOM.settingsPanel, DOM.settingsBtn);
                    };
                    document.addEventListener("click", (e) => {
                        if (
                            !DOM.cloakPanel.contains(e.target) &&
                            e.target !== DOM.cloakBtn &&
                            !DOM.settingsPanel.contains(e.target) &&
                            e.target !== DOM.settingsBtn
                        ) {
                            Panels.closeAll();
                        }
                    });
                    document.addEventListener("keydown", (e) => {
                        if (e.key === "Escape") Panels.closeAll();
                    });
                },
            };

            /* ── CLOAKER ── */
            const Cloaker = {
                originalTitle: document.title,
                originalFavicon: document.querySelector("link[rel='icon']")?.href || "",
                cloaked: false,

                init() {
                    const applyBtn = document.getElementById("apply-cloak");
                    const resetBtn = document.getElementById("reset-cloak");
                    const status = document.getElementById("cloak-status");
                    const titleInput = document.getElementById("custom-title");
                    const iconInput = document.getElementById("custom-favicon");

                    document.querySelectorAll(".preset-btn").forEach((pb) => {
                        pb.onclick = (e) => {
                            e.stopPropagation();
                            document.querySelectorAll(".preset-btn").forEach((p) => p.classList.remove("selected"));
                            pb.classList.add("selected");
                            titleInput.value = pb.dataset.title;
                            iconInput.value = pb.dataset.icon;
                        };
                    });

                    applyBtn.onclick = (e) => {
                        e.stopPropagation();
                        const title = titleInput.value.trim();
                        const favicon = iconInput.value.trim();
                        if (!title && !favicon) return;
                        if (title) document.title = title;
                        if (favicon) this.setFavicon(favicon);
                        this.cloaked = true;
                        DOM.cloakBtn.classList.add("active");
                        DOM.cloakBtn.innerHTML = ICON_EYE_ON;
                        status.classList.add("visible");
                        Panels.closeAll();
                    };

                    resetBtn.onclick = (e) => {
                        e.stopPropagation();
                        document.title = this.originalTitle;
                        this.setFavicon(
                            this.originalFavicon ||
                                "https://github.com/CorduroyBrick49/Atlas/blob/main/AtlasIcon.ico?raw=true"
                        );
                        this.cloaked = false;
                        DOM.cloakBtn.classList.remove("active");
                        DOM.cloakBtn.innerHTML = ICON_EYE_OFF;
                        status.classList.remove("visible");
                        titleInput.value = "";
                        iconInput.value = "";
                        document.querySelectorAll(".preset-btn").forEach((p) => p.classList.remove("selected"));
                    };
                },

                setFavicon(url) {
                    document
                        .querySelectorAll("link[rel='icon'], link[rel='shortcut icon']")
                        .forEach((el) => el.remove());
                    const link = Object.assign(document.createElement("link"), {
                        rel: "icon",
                        type: "image/x-icon",
                        href: url,
                    });
                    document.head.appendChild(link);
                },
            };

            /* ── BOOT ── */
            function init() {
                Theme.init();
                Theme.apply(Theme.getPreferred());
                Genres.init();
                Favorites.render();
                UI.render(data);
                DOM.search.addEventListener("input", Filters.apply.bind(Filters));
                Panels.init();
                Cloaker.init();
            }

            init();
        </script>
    </body>
</html>
